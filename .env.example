# ─── SERVIDOR ────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=cambia_esta_clave_secreta_larga

# ─── DASHBOARD ───────────────────────────────────────────────
DASHBOARD_PASSWORD=lc2024

# ─── OPENROUTER ──────────────────────────────────────────────
# Obtén tu clave en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
# Modelo recomendado con tool calling (gratuito o de pago):
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── SUPABASE (memoria de largo plazo + perfil por cliente) ──
# Opcional. Si se dejan vacías, el bot funciona sin memoria de largo plazo.
# La SECRET key se saca en: Supabase → Project Settings → API Keys → Secret keys
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# ─── GOOGLE CALENDAR ─────────────────────────────────────────
# Pasos para obtener credenciales:
# 1. Ir a https://console.cloud.google.com
# 2. Crear proyecto → Habilitar "Google Calendar API"
# 3. Credenciales → Crear OAuth 2.0 → Tipo: Web application
# 4. Descargar JSON y guardarlo como credentials.json en la raíz
# 5. La primera vez correr: node calendar/authorize.js
GOOGLE_CALENDAR_ID=tu_email@gmail.com
# Ruta al archivo de credenciales OAuth2 descargado de Google Cloud
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Ruta donde se guardará el token de acceso (se genera automáticamente)
GOOGLE_TOKEN_PATH=./token.json
